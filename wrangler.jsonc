{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "newenglandmesh-prod",
  "workers_dev": false,
  "preview_urls": false,
  "compatibility_date": "2026-06-13",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "build"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "env": {
    "staging": {
      "name": "newenglandmesh-staging",
      "workers_dev": false,
      "preview_urls": true
    }
  }
}
